NODE_ENV=development
PORT=3001

# PostgreSQL — local (Docker) o Neon
# Neon: usa el connection string POOLED (-pooler en el host) con ?sslmode=require
DATABASE_URL=postgresql://sharesplit:sharesplit_secret@localhost:5432/sharesplit
# PGSSL=1  # fuerza SSL si el string no lo indica

# JWT
JWT_SECRET=reemplaza_esto_con_un_secreto_seguro_de_al_menos_32_chars
JWT_EXPIRES_IN=7d

# CORS — frontend
# Lista literal coma-separada
CORS_ORIGIN=http://localhost:3000
# Regex coma-separadas para matchear previews de Vercel.
# Ejemplo: ^https:\/\/sharesplit-frontend(-[a-z0-9-]+)?\.vercel\.app$
CORS_ORIGIN_REGEX=

# Seguridad y tráfico
# En Render (detrás de proxy TLS) poné TRUST_PROXY=1
TRUST_PROXY=0
RATE_LIMIT_GLOBAL_MAX=800
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_PAYMENTS_MAX=80

# Pool de Postgres
PG_POOL_MAX=10