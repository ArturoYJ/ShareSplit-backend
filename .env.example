NODE_ENV=development
PORT=3001

# PostgreSQL — debe coincidir con infra/.env
DATABASE_URL=postgresql://sharesplit:sharesplit_secret@localhost:5432/sharesplit

# JWT
JWT_SECRET=reemplaza_esto_con_un_secreto_seguro_de_al_menos_32_chars
JWT_EXPIRES_IN=7d

# CORS — URL del frontend
CORS_ORIGIN=http://localhost:3000

# Seguridad y tráfico
TRUST_PROXY=0
RATE_LIMIT_GLOBAL_MAX=800
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_PAYMENTS_MAX=80
